<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Trắc Nghiệm Đúng/Sai</title>
    <style>
        :root { --primary: #4a90e2; --success: #4caf50; --error: #f44336; --bg: #f0f2f5; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: var(--bg); display: flex; justify-content: center; padding: 20px; margin: 0; }
        .container { background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 700px; }
        .header { display: flex; justify-content: space-between; margin-bottom: 15px; font-weight: bold; color: #444; border-bottom: 2px solid #eee; padding-bottom: 10px; }
        h2 { font-size: 1.1rem; color: #2c3e50; line-height: 1.6; background: #f8f9fa; padding: 15px; border-radius: 8px; margin-top: 0; }
        .row { display: flex; align-items: center; justify-content: space-between; padding: 12px; border-bottom: 1px solid #f0f0f0; transition: 0.3s; }
        .row:last-child { border-bottom: none; }
        .row.correct { background: #e8f5e9; }
        .row.wrong { background: #ffebee; }
        .content-text { flex: 1; margin-right: 15px; font-size: 0.95rem; color: #34495e; }
        .options-group { display: flex; gap: 8px; align-items: center; min-width: 150px; justify-content: flex-end; }
        .btn-opt { padding: 7px 14px; border: 1px solid #ccc; border-radius: 4px; cursor: pointer; background: white; font-size: 0.85rem; }
        .btn-opt.active-true { background: #27ae60; color: white; border-color: #27ae60; }
        .btn-opt.active-false { background: #e67e22; color: white; border-color: #e67e22; }
        .btn-opt:disabled { cursor: default; opacity: 0.8; }
        .check-btn, .next-btn { margin-top: 25px; width: 100%; padding: 14px; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; color: white; font-size: 1rem; transition: 0.3s; }
        .check-btn { background: #2ecc71; }
        .check-btn:hover { background: #27ae60; }
        .next-btn { background: var(--primary); display: none; }
        .feedback-icon { font-size: 1.1rem; margin-left: 8px; width: 20px; font-weight: bold; }
    </style>
</head>
<body>

<div class="container" id="quiz-box">
    <div class="header">
        <span id="progress">Đang chuẩn bị...</span>
        <span id="score-display">Điểm: 0</span>
    </div>
    <div id="question-area">
        <h2 id="question-text"></h2>
        <div id="sub-questions-container"></div>
    </div>
    
    <button class="check-btn" id="check-btn" onclick="checkAll()">Chấm điểm câu này</button>
    <button class="next-btn" id="next-btn" onclick="loadNextQuestion()">Tiếp theo</button>
</div>

<script>
    // Dữ liệu thô từ file của bạn
    const rawContent = `Câu . Mỗi nhận định sau là đúng hay sai khi nói về ý nghĩa của việc ứng dụng nhân giống vô tính trong ống nghiệm ở cây trồng?|
a) Giúp tạo ra giống có nhiều ưu điểm như sạch nấm bệnh, đồng đề về đặc tính của giống gốc. Đ|
b) Giúp bảo tồn một số nguồn gen thực vật quý hiếm có nguy cơ tuyệt chủng. Đ|
c) Giúp nhân nhanh giống cây trồng đáp ứng yêu cầu của sản xuất. Đ|		
d) Giúp tạo ra nhiều biến dị tốt. S|
#
Câu . Trong quá trình làm tiêu bản quan sát quá trình giảm phân ở châu chấu, học sinh đã tiến hành quan sát dưới kính hiển vi và ghi nhận lại các hình ảnh đại diện cho từng giai đoạn khác nhau của quá trình giảm phân như sau:|
a) Quá trình giảm phân ở châu chấu đực diễn ra trong tinh hoàn.Đ|
b) Kính hiển vi điện tử là công cụ bắt buộc để quan sát tiêu bản giảm phân.S|
c) Tế bào h) ở hình trên đang ở kì đầu của giảm phân I.Đ|
d) Quá trình giảm phân ở châu chấu tạo ra 2 tế bào con mang bộ NST đơn bội (n).S|
#
Câu . Hình mô tả về quy trình của phương pháp nhân bản vô tính động vật (cừu):| 
a) [1] là lấy tế bào chất từ trứng của cừu cho nhân (A).S|
b) [2] là bỏ nhân trong trứng của cừu cho tế bào chất từ cừu cho trứng (B).Đ|
c) Bộ gene trong nhân tế bào của [3] và [4] giống hệt nhau.Đ|
d) Bộ gene trong nhân tế bào của [5] giống cừu A, bộ gene trong tế bào chất của cừu B và [5] giống nhau.Đ|
#
Câu . Mỗi nhận định sau là đúng hay sai khi nói về ý nghĩa của nguyên phân đối với sinh vật nhân thực đa bào?|
a) Là cơ sở sinh sản vô tính.Đ|
b) Tạo nên sự đa dạng di truyền.S|
c) Giúp ổn định bộ nhiễm sắc thể qua các thế hệ.S|
d) Giúp thay thế các tế bào già, sai hỏng.Đ|
#
Câu . Hình bên dưới mô tả khái quát quá trình phân chia của một tế bào. Mỗi mệnh đề sau là đúng hay sai?|
a) Trật tự chính xác về các giai đoạn của quá trình phân bào này là: 
A 🡪 B 🡪 G 🡪 F 🡪 E 🡪 C 🡪 D.Đ|
b) Đây là quá trình giảm phân.S|
c) Giai đoạn E đang ở kì giữa I của quá trình giảm phân.Đ|
d) Giai đoạn C đang ở kì sau của quá trình nguyên phân.S|
#
Câu . Ngựa có bộ nhiễm sắc thể 2n = 64 và lừa có bộ nhiễm sắc thể 2n = 62, mỗi nhận định sau đây là Đúng hay Sai ?|	
a) Quá trình giảm phân xảy ra bình thường thì giao tử của ngựa có bộ NST n=32. Đ|
b) Trong quá trình giảm phân tạo giao tử của con lừa, ở kì sau giảm phân II quan sát thấy 62 cromatit.Đ|
c) Con la sinh sản bình thường.S|
d) Con la có bộ NST lưỡng bội là 2n= 63.Đ|
	`;

    let questions = [];
    let currentIdx = 0;
    let totalScore = 0;
    let userChoices = [];
    let currentShuffledSubs = [];

    function parseData() {
        const blocks = rawContent.split('#');
        questions = blocks.map(block => {
            const lines = block.trim().split('|');
            if (lines.length < 2) return null;
            
            const title = lines[0].trim();
            const subs = lines.slice(1).filter(l => l.trim() !== "").map(line => {
                const cleanLine = line.trim();
                // Lấy ký tự cuối cùng làm đáp án (Đ hoặc S)
                const ansChar = cleanLine.slice(-1).toUpperCase();
                // Bỏ phần "a) " ở đầu và " Đ" ở cuối
                const text = cleanLine.substring(2, cleanLine.length - 1).trim();
                return { text: text, ans: (ansChar === 'Đ') };
            });
            return { title, subs };
        }).filter(q => q !== null);
        
        questions.sort(() => Math.random() - 0.5);
        renderQuestion();
    }

    function renderQuestion() {
        const q = questions[currentIdx];
        document.getElementById("progress").innerText = `Câu ${currentIdx + 1} / ${questions.length}`;
        document.getElementById("question-text").innerText = q.title;
        
        const container = document.getElementById("sub-questions-container");
        container.innerHTML = "";
        
        // Xáo trộn vị trí a, b, c, d
        currentShuffledSubs = [...q.subs].sort(() => Math.random() - 0.5);
        userChoices = new Array(currentShuffledSubs.length).fill(null);
        
        const labels = ['a', 'b', 'c', 'd', 'e', 'f'];

        currentShuffledSubs.forEach((sub, i) => {
            const div = document.createElement("div");
            div.className = "row";
            div.innerHTML = `
                <div class="content-text"><strong>${labels[i]})</strong> ${sub.text}</div>
                <div class="options-group">
                    <button class="btn-opt" onclick="setChoice(this, ${i}, true)">Đúng</button>
                    <button class="btn-opt" onclick="setChoice(this, ${i}, false)">Sai</button>
                    <span class="feedback-icon" id="fb-${i}"></span>
                </div>
            `;
            container.appendChild(div);
        });
        
        document.getElementById("check-btn").style.display = "block";
        document.getElementById("next-btn").style.display = "none";
    }

    function setChoice(btn, idx, val) {
        const group = btn.parentElement;
        group.querySelectorAll('.btn-opt').forEach(b => b.classList.remove('active-true', 'active-false'));
        btn.classList.add(val ? 'active-true' : 'active-false');
        userChoices[idx] = val;
    }

    function checkAll() {
        if (userChoices.includes(null)) {
            alert("Bạn chưa chọn hết các ý Đúng/Sai!");
            return;
        }

        const rows = document.querySelectorAll(".row");
        let roundScore = 0;

        userChoices.forEach((choice, i) => {
            const isCorrect = (choice === currentShuffledSubs[i].ans);
            const fb = document.getElementById(`fb-${i}`);
            
            if (isCorrect) {
                rows[i].classList.add("correct");
                fb.innerText = "✓";
                fb.style.color = "#27ae60";
                roundScore++;
            } else {
                rows[i].classList.add("wrong");
                fb.innerText = "✕";
                fb.style.color = "#c0392b";
            }
        });

        totalScore += roundScore;
        document.getElementById("score-display").innerText = `Điểm: ${totalScore}`;
        document.getElementById("check-btn").style.display = "none";
        document.getElementById("next-btn").style.display = "block";
        document.querySelectorAll('.btn-opt').forEach(b => b.disabled = true);
    }

    function loadNextQuestion() {
        currentIdx++;
        if (currentIdx < questions.length) {
            renderQuestion();
        } else {
            alert("Hoàn thành! Tổng điểm của bạn: " + totalScore);
            location.reload();
        }
    }

    parseData();
</script>
</body>
</html>
